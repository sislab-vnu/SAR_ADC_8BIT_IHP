# ===============================
# Portable xschemrc for TESTBENCH
# ===============================

# Load PDK config
source $::env(PDK_ROOT)/$::env(PDK)/libs.tech/xschem/xschemrc

# --------------------------------
# Get TESTBENCH root
# --------------------------------
set TB_ROOT [file dirname [info script]]

# --------------------------------
# Init library path
# --------------------------------
if {![info exists XSCHEM_LIBRARY_PATH]} {
    set XSCHEM_LIBRARY_PATH ""
}

# --------------------------------
# Add MAIN ANALOG BLOCKS
# --------------------------------
append XSCHEM_LIBRARY_PATH :$TB_ROOT/../xschem

# --------------------------------
# Add DIGITAL SAR LOGIC
# --------------------------------
append XSCHEM_LIBRARY_PATH :$TB_ROOT/../algorithm/xschem

# --------------------------------
# Add local testbench folder (optional)
# --------------------------------
append XSCHEM_LIBRARY_PATH :$TB_ROOT
